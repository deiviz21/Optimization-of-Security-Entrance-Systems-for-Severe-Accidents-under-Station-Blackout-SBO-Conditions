EXEC_TEND		172800.0 !48 hours
!			size
EXEC_TIME	5	!n	time		dtmax		dtmin			dtedit			dtplot			dtrest			dcrest
			1       0.0   		0.1     	0.001    		400.0    		1000.0    		5000.0
			2	3600.0		0.02		0.0001			400.0			40.0			5000.0
			3  	21600.0   	0.1     	0.001    		400.0    		100.0    		5000.0	! 6 horas
			4   	43200.0  	0.5     	0.001   	        500.0     		500.0   		50000.0	! 12 horas
			5	86400.0 	1.0		0.1			500.0			500.0			5000.0	! 48 horas
	
!EXEC_TIME	1	!n	time		dtmax		dtmin			dtedit			dtplot			dtrest			dcrest
!			1       0.0   		50.0     	1.0    		400.0    		1000.0    		5000.0
!			2	3600.0		0.02		0.0001			400.0			40.0			5000.0
!			3  	21600.0   	0.1     	0.001    		400.0    		100.0    		5000.0	! 6 horas
!			4   	43200.0  	0.5     	0.001   	        500.0     		500.0   		50000.0	! 12 horas
