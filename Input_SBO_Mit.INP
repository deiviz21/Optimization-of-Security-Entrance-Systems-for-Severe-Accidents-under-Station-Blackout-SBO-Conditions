!			ncfarg			ftext
CF_FORMULA	5				D*(k5*vH2+k6*vCO)		!n			shortname			charg		!
													1			D					100.0		! the result is given in %
													2			k5					1.19
													3			vH2					CVH-X(CAVITY,H2)
													4			k6					0.49
													5			vCO					CVH-X(CAVITY,CO)
