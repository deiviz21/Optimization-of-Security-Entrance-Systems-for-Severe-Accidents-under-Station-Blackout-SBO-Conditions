CF_ID		'H2_loss.da'		326			FORMULA
!			ncfarg		ftext		
CF_FORMULA	7			s*(k1*p+k2)*TANH(aux)*nH2*Coff		!n		shorname	charg
															1		s			-1.0		!it is a sink
															2		k1			1.37E-9		!I.S. units
															3		p			CVH-P(DOME)
															4		k2			1.67E-4		!I.S. units
															5		aux			CF-VALU('aux_3.d')
															6		nH2			CF-VALU('ettaH2.d')
															7		Coff		CF-VALU('Coff.d')
