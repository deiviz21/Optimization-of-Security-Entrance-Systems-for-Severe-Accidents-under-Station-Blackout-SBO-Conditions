CF_FORMULA	7		k7*((k1*p+k2)*TANH(aux)*nCO*Coff)		!n		shortname	charg
															1		k7			-14.0			!it's a sink
															2		k1			1.37E-9			!I.S units
															3		p			CVH-P(DOME)		!pressure [Pa] 		
															4		k2			1.67E-4			!I.S.units
															5		aux			CF-VALU(aux_3.d)
															6		nCO			CF-VALU('ettaCO.d')
															7		Coff		CF-VALU('Coff.d')
